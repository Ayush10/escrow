# Example provider onboarding configuration for local development.

GOAT_RPC_URL=https://rpc.testnet3.goat.network
GOAT_CHAIN_ID=48816
ESCROW_CONTRACT_ADDRESS=0xFBf9b5293A1737AC53880d3160a64B49bA54801D

# Provider identity
PROVIDER_PRIVATE_KEY=0x<provider-private-key>
X402_SELLER_WALLET=0x<provider-wallet-address>

# x402 payments
X402_FACILITATOR_URL=https://www.x402.org/facilitator
X402_NETWORK=eip155:84532

# Local development
X402_ALLOW_MOCK=1
ESCROW_DRY_RUN=1
