{
  "name": "verdict-protocol-python",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "demo": "bash ./scripts/demo.sh",
    "demo:console": "bash ./scripts/demo.sh --console",
    "demo:happy": "bash ./scripts/demo.sh --happy",
    "demo:dispute": "bash ./scripts/demo.sh --dispute",
    "demo:ui": "python3 -m http.server 4173 --directory console",
    "dashboard:payment": "bash ./scripts/run_module.sh demo_runner.push_dashboard_payment",
    "dev:evidence": "bash ./scripts/run_module.sh evidence_service.server",
    "dev:judge": "bash ./scripts/run_module.sh judge_service.server",
    "dev:reputation": "bash ./scripts/run_module.sh reputation_service.api",
    "dev:provider": "bash ./scripts/run_module.sh provider_api.server",
    "dev:runner": "bash ./scripts/run_module.sh demo_runner.server",
    "dev:mcp": "uv run python -m protocol_mcp.server",
    "dev:frontend": "python3 -m http.server 4173 --directory console",
    "test": "uv run pytest"
  }
}
